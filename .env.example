# Resend (https://resend.com) — get an API key in the dashboard
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives form submissions
TO_EMAIL=you@example.com

# From address. Testing: "Portfolio <onboarding@resend.dev>"
